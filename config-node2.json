{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "inbounds": [
    // ========== 你原有的 VLESS+WS 入站（保持不变） ==========
    {
      "type": "vless",
      "tag": "vless-ws-in",
      "listen": "::",
      "listen_port": 8080,
      "sniff": true,
      "sniff_override_destination": true,
      "users": [
        {
          "uuid": "3a36d77e-fe4d-45db-af05-b6f71760fc5a",
          "name": "user1"
        }
      ],
      "transport": {
        "type": "ws",
        "path": "/chat",
        "max_early_data": 2048,
        "early_data_header_name": "Sec-WebSocket-Protocol"
      }
    },
    // ========== 新增：HTTP 测速入站（供对端测试本机存活） ==========
    {
      "type": "http",
      "tag": "speedtest-in",
      "listen": "0.0.0.0",
      "listen_port": 8081,          // 使用新端口，避免与 8080 冲突
      "sniff": false                // 测速无需嗅探
    }
  ],
  "outbounds": [
    // ========== 原有的直连出站 ==========
    {
      "type": "direct",
      "tag": "direct"
    },

    // ========== 新增：返回 204 响应的出站（用于测速响应） ==========
    {
      "type": "return",
      "tag": "response-204",
      "data": "SFRUUC8xLjEgMjA0IE5vIENvbnRlbnQNCg0K"   // 204 No Content 的 Base64
    },

    // ========== 新增：指向对端（节点 B）的 VLESS 出站 ==========
    {
      "type": "vless",
      "tag": "node-b-out",
      "server": "对端IP",            // 替换为节点 B 的公网 IP 或域名
      "server_port": 8080,          // 节点 B 的 VLESS 入站端口
      "uuid": "对端B的UUID",         // 替换为节点 B 的 users.uuid
      "transport": {
        "type": "ws",
        "path": "/chat",            // 需与节点 B 的 path 一致
        "max_early_data": 2048,
        "early_data_header_name": "Sec-WebSocket-Protocol"
      },
      "tls": {
        "enabled": false            // 若使用 TLS 则改为 true 并配置证书
      }
    },

    // ========== 新增：urltest 出站组（定期通过节点 B 测速） ==========
    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": [
        "node-b-out"                // 使用刚才定义的指向 B 的出站
      ],
      "url": "http://www.gstatic.com/generate_204",  // 公网测速地址
      "interval": "5m",            // 每 5 分钟测一次
      "tolerance": 50,
      "idle_timeout": "30m"
    }
  ],
  "route": {
    "rules": [
      // ========== 规则 1：来自测速入站且路径为 /generate_204 的请求，直接返回 204 ==========
      {
        "inbound": ["speedtest-in"],
        "path": ["/generate_204"],
        "outbound": "response-204"
      }
      // 可根据需要添加其他路由规则，例如默认流量走 direct
    ],
    "final": "direct"               // 未匹配的流量走直连
  }
}
